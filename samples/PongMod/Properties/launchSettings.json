{
  "profiles": {
    "Run Pong": {
      "commandName": "Executable",
      "executablePath": "$(SolutionDir)/src/Sparkitect/bin/$(Configuration)/net10.0/Sparkitect",
      "commandLineArgs": "-addModDirs=$(ProjectDir)/bin/$(Configuration)/net10.0",
      "workingDirectory": "$(ProjectDir)/.run"
    },
    "Run Pong + BackgroundColor": {
      "commandName": "Executable",
      "executablePath": "$(SolutionDir)/src/Sparkitect/bin/$(Configuration)/net10.0/Sparkitect",
      "commandLineArgs": "-addModDirs=$(ProjectDir)/bin/$(Configuration)/net10.0;$(SolutionDir)/samples/BackgroundColorMod/bin/$(Configuration)/net10.0",
      "workingDirectory": "$(ProjectDir)/.run"
    },
    "Run Pong + All Color Mods": {
      "commandName": "Executable",
      "executablePath": "$(SolutionDir)/src/Sparkitect/bin/$(Configuration)/net10.0/Sparkitect",
      "commandLineArgs": "-addModDirs=$(ProjectDir)/bin/$(Configuration)/net10.0;$(SolutionDir)/samples/BackgroundColorMod/bin/$(Configuration)/net10.0;$(SolutionDir)/samples/ColorProviderMod/bin/$(Configuration)/net10.0",
      "workingDirectory": "$(ProjectDir)/.run"
    }
  }
}
