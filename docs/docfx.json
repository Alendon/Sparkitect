{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "Sparkitect/bin/Release/**/Sparkitect.dll",
            "Sparkitect/bin/Release/**/Sparkitect.Graphics.Vulkan.Vma.dll"
          ],
          "src": "../src"
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml",
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": ["**.{md,yml}"],
        "exclude": ["filterConfig.yml"]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "Sparkitect Documentation",
      "_appFooter": "\u00a9 2026 Sparkitect Game Engine",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_disableContribution": false,
      "_disableNavbar": false,
      "_disableBreadcrumb": false,
      "_disableToc": false,
      "_disableAffix": false,
      "_gitContribute": {
        "repo": "https://github.com/Alendon/Sparkitect",
        "branch": "main"
      }
    },
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "templates/singulinkfx"
    ],
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}
