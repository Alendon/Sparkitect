<idea-plugin require-restart="true">
  <id>Sparkitect.RiderPlugin</id>
  <name>Sparkitect</name>
  <version>0.1.0</version>
  <vendor>Sparkitect</vendor>
  <idea-version since-build="261" />
  <depends>com.intellij.modules.rider</depends>
  <!--
    Non-optional: the Sparkres frontend file type borrows org.jetbrains.yaml's
    YAMLSyntaxHighlighterFactory for editor coloring and the plugin maps
    .sparkres.yaml onto a Rider-backed file type so the ReSharper backend's YAML
    PSI/references/highlightings surface in the editor. YAML ships bundled in Rider.
  -->
  <depends>org.jetbrains.plugins.yaml</depends>

  <!--
    Routes *.sparkres.yaml onto a Rider-backed file type (RiderLanguageFileTypeBase +
    a dummy-lexer parser definition). This is what makes Rider open the file as a
    backend document so the backend's registration references (F12) and daemon
    highlightings render in the editor; the stock YAML editor ignores the backend.
    Scoped via the patterns attribute so plain *.yaml keeps the stock YAML editor.

    The rd.languageAssociation + backend.* extensions are the protocol bridge that
    actually surfaces backend results: rd.languageAssociation binds the open frontend
    SparkresYaml document to its backend PSI language (plain YAML, since the backend
    file type derives YamlProjectFileType), which is what makes the per-document daemon
    run in VISIBLE_DOCUMENT mode for the focused editor; markup.adapterFactory streams
    the daemon's highlightings into the editor; actions.support routes editor actions
    (go-to-declaration / F12) to the backend; typedHandler makes typing backend-aware.
    Without these the backend only ever runs the solution-wide sweep (SOLUTION_ANALYSIS)
    and nothing reaches the editor. Mirrors the Unity plugin's UnityYaml registration.
  -->
  <extensions defaultExtensionNs="com.intellij">
    <fileType name="SparkresYaml" fieldName="INSTANCE"
              implementationClass="sparkitect.riderplugin.yaml.SparkresYamlFileType"
              language="SparkresYaml"
              patterns="*.sparkres.yaml" />
    <lang.parserDefinition language="SparkresYaml"
              implementationClass="sparkitect.riderplugin.yaml.SparkresYamlParserDefinition" />
    <lang.syntaxHighlighterFactory language="SparkresYaml"
              implementationClass="org.jetbrains.yaml.YAMLSyntaxHighlighterFactory" />

    <!--
      The GSM Debugger tool window. Always available with no availability condition so its
      explanatory empty states are reachable whether or not a Sparkitect game is running; the factory
      binds the republished DebugToolWindowModel Ext. The backend is the sole game-channel client —
      the frontend never opens the game SocketWire directly.
    -->
    <toolWindow id="Sparkitect Game State" anchor="bottom"
              factoryClass="sparkitect.riderplugin.debug.GameStateToolWindowFactory" />

    <!--
      The Sparkitect Explorer tool window. Always available (no availability condition) so its
      empty states are reachable regardless of solution contents; the factory binds the Solution-scoped
      ExplorerModel Ext (backend PSI walk), a sibling of the Game State window. Anchored left as a
      browsable structure explorer distinct from the bottom-anchored runtime Game State inspector.
    -->
    <toolWindow id="Sparkitect Explorer" anchor="left"
              factoryClass="sparkitect.riderplugin.explorer.ExplorerToolWindowFactory" />

    <rd.languageAssociation backendLanguage="YAML" frontendLanguage="SparkresYaml" />
    <backend.markup.adapterFactory language="SparkresYaml"
              implementationClass="com.jetbrains.rdclient.daemon.FrontendMarkupAdapterFactory" />
    <backend.actions.support language="SparkresYaml"
              implementationClass="com.jetbrains.rider.actions.RiderActionSupportPolicy" />
    <backend.typedHandler language="SparkresYaml"
              implementationClass="com.jetbrains.rider.editorActions.FrontendTypedHandler" />
  </extensions>

  <!--
    Go to Registration: a frontend RiderAnAction whose backend id "GoToRegistration" matches the backend
    [Action] IExecutableAction of the same id, routed over the existing RD protocol with no rdgen model.
    Added as the top entry of the editor context menu's Go To submenu (EditorPopupMenu.GoTo) as a peer to
    Go to Definition. No forced keystroke so the binding stays keymap-configurable.
  -->
  <actions>
    <action id="GoToRegistration"
            class="sparkitect.riderplugin.actions.GoToRegistrationAction"
            text="Registration"
            description="Navigate from a generated identification to its registration site">
      <add-to-group group-id="EditorPopupMenu.GoTo" anchor="first" />
    </action>
    <action id="GoToOrderTarget"
            class="sparkitect.riderplugin.actions.GoToOrderTargetAction"
            text="Order Target"
            description="Navigate from an OrderAfter/OrderBefore argument to the authored method">
      <add-to-group group-id="EditorPopupMenu.GoTo" anchor="first" />
    </action>
  </actions>

  <description>
<![CDATA[
<p>Navigation support for Sparkitect mod registrations and their generated identification symbols.</p>
]]>
  </description>
</idea-plugin>
