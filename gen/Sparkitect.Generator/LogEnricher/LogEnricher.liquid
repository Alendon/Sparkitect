#pragma warning disable CS9113
#pragma warning disable CS1591

namespace {{ interceptorNamespace }};

[global::System.Runtime.CompilerServices.CompilerGeneratedAttribute]
file class {{ fullClassName }}
{
    
    {% for intercept in interceptions %}
    
    {{ intercept.interceptLocationAttribute }}    
    public static void LogIntercept_{{ forloop.index }}(
    {%- unless intercept.staticCall -%}
    this {{ intercept.targetClass }} __value
        {%- unless intercept.parameters.size == 0-%},{%- endunless -%}
    {%- endunless -%}
    {%- for param in intercept.parameters -%}
    {{ param.type }} {{ param.name }}{% unless forloop.last %}, {%- endunless -%}
    {%- endfor -%}
)
    {
        using var modNameContext = global::Serilog.Context.LogContext.PushProperty("ModName", "{{modName}}");
        using var classNameContext = global::Serilog.Context.LogContext.PushProperty("ClassName", "{{className}}");
        
        {% if intercept.staticCall -%}
        {{- intercept.targetClass -}}
        {%- else -%}
        __value
        {%- endif -%}
        .{{ intercept.targetMethod }}(
        {%- for param in intercept.parameters -%}
        {{ param.name }}{% unless forloop.last %}, {%- endunless -%}
        {%- endfor -%}
        );
    }
    {% endfor %}
}