namespace {{ Namespace }};

using Sparkitect.Modding;
using Sparkitect.DI;
using Sparkitect.DI.Container;

[global::Sparkitect.DI.RegistrationsEntrypoint]
public class {{ RegistryName }}Registrations(global::Sparkitect.Modding.IIdentificationManager identificationManager) : global::Sparkitect.DI.Registrations<global::{{ RegistryFullName }}>
{
    public override string CategoryIdentifier => "{{ CategoryKey }}";

{% for entry in Entries -%}
    public static global::Sparkitect.Modding.Identification {{ entry.PropertyName }} { get; private set; }
{% endfor %}
{% for entry in MethodProviders -%}
    public static global::Sparkitect.Modding.Identification {{ entry.PropertyName }} { get; private set; }
{% endfor %}
{% for entry in TypeProviders -%}
    public static global::Sparkitect.Modding.Identification {{ entry.PropertyName }} { get; private set; }
{% endfor %}

    public override void PrePhaseRegistration(global::{{ RegistryFullName }} registry, global::Sparkitect.DI.Container.ICoreContainer container) { }

    public override void MainPhaseRegistration(global::{{ RegistryFullName }} registry, global::Sparkitect.DI.Container.ICoreContainer container)
    {

{% for entry in Entries -%}
        {{ entry.PropertyName }} = identificationManager.RegisterObject("{{ ModNameSnakeCase }}", "{{ CategoryKey }}", "{{ entry.Id }}");

{% endfor -%}

{% for mp in MethodProviders -%}
        {%- for p in mp.Parameters %}
        {%- if p.IsNullable -%}
        container.TryResolve(out {{ p.Type }} {{ p.Var }});
        {%- else -%}
        if (!container.TryResolve(typeof({{ p.Type }}), out var tmp{{ p.Var }}))
            throw new global::Sparkitect.DI.Exceptions.DependencyResolutionException("Missing dependency {{ p.Type }} for provider {{ mp.ProviderFullName }}");
        var {{ p.Var }} = ({{ p.Type }})tmp{{ p.Var }}!;
        {%- endif %}
        {%- endfor %}
        var _value_{{ mp.PropertyName }} = {{ mp.ProviderFullName }}({%- for p in mp.Parameters -%}{{ p.Var }}{%- unless forloop.last %}, {% endunless -%}{%- endfor -%});
        {{ mp.PropertyName }} = identificationManager.RegisterObject("{{ ModNameSnakeCase }}", "{{ CategoryKey }}", "{{ mp.Id }}");
        registry.{{ mp.RegistryMethodName }}({{ mp.PropertyName }}, _value_{{ mp.PropertyName }});

{% endfor -%}

{% for tp in TypeProviders -%}
        {{ tp.PropertyName }} = identificationManager.RegisterObject("{{ ModNameSnakeCase }}", "{{ CategoryKey }}", "{{ tp.Id }}");
        registry.{{ tp.RegistryMethodName }}<{{ tp.TypeFullName }}>({{ tp.PropertyName }});

{% endfor -%}
    }

    public override void PostPhaseRegistration(global::{{ RegistryFullName }} registry, global::Sparkitect.DI.Container.ICoreContainer container) { }
}
