namespace {{ Namespace }};

using Sparkitect.Modding;
using Sparkitect.DI;
using Sparkitect.DI.Container;

[global::Sparkitect.DI.RegistrationsEntrypoint<global::{{ RegistryFullName }}>]
public class {{ RegistryName }}Registrations_{{ SourceTag }} : global::Sparkitect.DI.Registrations<global::{{ RegistryFullName }}>
{
    public override string CategoryIdentifier => "{{ CategoryKey }}";

{% for entry in Entries -%}
    public static global::Sparkitect.Modding.Identification {{ entry.PropertyName }} { get; private set; }
{% endfor %}
    
    public override void ProcessRegistrations(global::{{ RegistryFullName }} registry)
    {
{% for e in Entries -%}
        {
            {{ e.PropertyName }} = IdentificationManager.RegisterObject("{{ ModId }}", "{{ CategoryKey }}", "{{ e.Id }}");
{% if e.Files and e.Files.size > 0 -%}
            {%- for f in e.Files %}
            ResourceManager?.SetResource({{ e.PropertyName }}, "{{ f.fileId }}", "{{ f.fileName }}");
            {%- endfor %}
{% endif -%}
{% if e.Kind == "Method" -%}
            {%- for p in e.DiParams %}
            {%- if p.IsNullable -%}
            Container.TryResolve<{{ p.Type }}>(out var arg_{{ forloop.index0 }});
            {%- else -%}
            if(!Container.TryResolve<{{ p.Type }}>(out var arg_{{ forloop.index0 }}))
                throw new global::System.InvalidOperationException("Missing dependency {{ p.Type }} for provider {{ e.ProviderFullName }}");
            {%- endif -%}
            {%- endfor %}
            var value = {{ e.ProviderFullName }}({%- for p in e.DiParams -%}{% if forloop.index0 > 0 %}, {% endif %}arg_{{ forloop.index0 }}{%- endfor -%});
            registry.{{ e.MethodName }}({{ e.PropertyName }}, value);
{% elsif e.Kind == "Property" -%}
            var value = {{ e.ProviderFullName }};
            registry.{{ e.MethodName }}({{ e.PropertyName }}, value);
{% elsif e.Kind == "Type" -%}
            registry.{{ e.MethodName }}<{{ e.TypeFullName }}>({{ e.PropertyName }});
{% elsif e.Kind == "Resource" -%}
            {%- if e.MethodName != "" %}registry.{{ e.MethodName }}({{ e.PropertyName }});{%- endif %}
{% endif -%}
        }
{% endfor -%}
    } 
}
