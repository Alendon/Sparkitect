# Committed rd-gen output (C#-reversed debug-channel endpoint). rd-gen's file header opens with a
# divider line, so Roslyn's `<auto-generated>` first-comment heuristic does not fire and the public
# generated members would otherwise trip the engine-wide CS1591 doc gate under -warnaserror. Scope the
# suppression to this generated folder only; the rest of the engine keeps full doc enforcement.
[*.cs]
generated_code = true
dotnet_diagnostic.CS1591.severity = none
