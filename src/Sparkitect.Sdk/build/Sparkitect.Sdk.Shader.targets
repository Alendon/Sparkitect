<Project>

    <PropertyGroup>
        <!-- Configurable slangc path with fallbacks -->
        <SlangCompilerPath Condition="'$(SlangCompilerPath)' == '' AND '$(VULKAN_SDK)' != '' AND Exists('$(VULKAN_SDK)/bin/slangc')">$(VULKAN_SDK)/bin/slangc</SlangCompilerPath>
        <SlangCompilerPath Condition="'$(SlangCompilerPath)' == '' AND '$(VULKAN_SDK)' != '' AND Exists('$(VULKAN_SDK)/bin/slangc.exe')">$(VULKAN_SDK)/bin/slangc.exe</SlangCompilerPath>
        <SlangCompilerPath Condition="'$(SlangCompilerPath)' == ''">slangc</SlangCompilerPath>

        <!-- Configurable spirv-val path with fallbacks (mirrors SlangCompilerPath) -->
        <SpirvValPath Condition="'$(SpirvValPath)' == '' AND '$(VULKAN_SDK)' != '' AND Exists('$(VULKAN_SDK)/bin/spirv-val')">$(VULKAN_SDK)/bin/spirv-val</SpirvValPath>
        <SpirvValPath Condition="'$(SpirvValPath)' == '' AND '$(VULKAN_SDK)' != '' AND Exists('$(VULKAN_SDK)/bin/spirv-val.exe')">$(VULKAN_SDK)/bin/spirv-val.exe</SpirvValPath>
        <SpirvValPath Condition="'$(SpirvValPath)' == ''">spirv-val</SpirvValPath>

        <!-- Resource directory (may be redefined in Sparkitect.Sdk.targets, but needed here for early evaluation) -->
        <SparkitectResourceDirectory Condition="'$(SparkitectResourceDirectory)' == ''">$(MSBuildProjectDirectory)/Resources</SparkitectResourceDirectory>

        <!-- Default shader output directory -->
        <SlangShaderOutputPath Condition="'$(SlangShaderOutputPath)' == ''">$(SparkitectResourceDirectory)/shaders</SlangShaderOutputPath>

        <!-- Default include paths -->
        <SlangIncludePaths Condition="'$(SlangIncludePaths)' == ''">$(MSBuildProjectDirectory)/Shaders</SlangIncludePaths>
    </PropertyGroup>

    <!-- Visual Studio Fast Up-to-Date Check integration -->
    <ItemGroup>
        <UpToDateCheckInput Include="@(SlangShader)" />
    </ItemGroup>

    <Target Name="CompileSlangShaders"
            BeforeTargets="BeforeBuild"
            Condition="'@(SlangShader)' != ''"
            Inputs="@(SlangShader)"
            Outputs="@(SlangShader->'$(SlangShaderOutputPath)/%(Filename).spv')">

        <!-- Create output directory -->
        <MakeDir Directories="$(SlangShaderOutputPath)" />

        <!-- Convert include paths to item group for transformation -->
        <ItemGroup>
            <_SlangIncludePath Include="$(SlangIncludePaths)" />
        </ItemGroup>

        <!-- Build include path arguments -->
        <PropertyGroup>
            <_SlangIncludeArgs>@(_SlangIncludePath->'-I"%(Identity)"', ' ')</_SlangIncludeArgs>
        </PropertyGroup>

        <!-- Compile each shader -->
        <Exec Command="&quot;$(SlangCompilerPath)&quot; &quot;%(SlangShader.FullPath)&quot; -target spirv -o &quot;$(SlangShaderOutputPath)/%(SlangShader.Filename).spv&quot; $(_SlangIncludeArgs) %(SlangShader.AdditionalOptions)"
              WorkingDirectory="$(MSBuildProjectDirectory)"
              StandardOutputImportance="Low"
              StandardErrorImportance="High" />

        <!-- Register outputs for FUTDC -->
        <ItemGroup>
            <UpToDateCheckBuilt Include="$(SlangShaderOutputPath)/%(SlangShader.Filename).spv"
                                Original="%(SlangShader.FullPath)" />
        </ItemGroup>
    </Target>

    <!-- Validate compiled SPIR-V with spirv-val: hard gate when the tool is present, skipped cleanly when absent -->
    <Target Name="ValidateSlangShaders"
            AfterTargets="CompileSlangShaders"
            Condition="'@(SlangShader)' != ''">

        <!-- Probe for spirv-val. A bare PATH tool cannot be detected with Exists, so run the version
             query with ContinueOnError and capture the exit code (0 = present, non-zero = absent). -->
        <Exec Command="&quot;$(SpirvValPath)&quot; --version"
              ContinueOnError="true"
              StandardOutputImportance="Low"
              StandardErrorImportance="Low">
            <Output TaskParameter="ExitCode" PropertyName="_SpirvValProbeExitCode" />
        </Exec>

        <!-- Real validation runs only when the probe found the tool. Default error handling
             (ContinueOnError false) makes invalid SPIR-V a HARD build failure. -->
        <Exec Condition="'$(_SpirvValProbeExitCode)' == '0'"
              Command="&quot;$(SpirvValPath)&quot; &quot;$(SlangShaderOutputPath)/%(SlangShader.Filename).spv&quot;"
              WorkingDirectory="$(MSBuildProjectDirectory)"
              StandardOutputImportance="Low"
              StandardErrorImportance="High" />

        <Message Condition="'$(_SpirvValProbeExitCode)' != '0'"
                 Importance="Normal"
                 Text="spirv-val not found (probe exit $(_SpirvValProbeExitCode)); skipping SPIR-V validation." />
    </Target>

    <!-- Clean target -->
    <Target Name="CleanSlangShaders" AfterTargets="Clean">
        <Delete Files="@(SlangShader->'$(SlangShaderOutputPath)/%(Filename).spv')" />
    </Target>

</Project>
